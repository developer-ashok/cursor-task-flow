{
  "name": "cursor-task-flow",
  "displayName": "Cursor Task Flow",
  "description": "Manage and inject task prompts into Cursor AI Chat.",
  "version": "0.0.3",
  "publisher": "developer-ashok",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/developer-ashok/cursor-task-flow"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:cursorTaskFlowView",
    "onCommand:cursorTaskFlow.addTask",
    "onCommand:cursorTaskFlow.deleteTask",
    "onCommand:cursorTaskFlow.refreshTasks",
    "onCommand:cursorTaskFlow.injectTask",
    "onCommand:cursorTaskFlow.openLogs"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorTaskFlowContainer",
          "title": "Tasks",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cursorTaskFlowContainer": [
        {
          "id": "cursorTaskFlowView",
          "name": "Project Tasks"
        }
      ]
    },
    "commands": [
      {
        "command": "cursorTaskFlow.refreshTasks",
        "title": "Refresh Tasks",
        "icon": "$(refresh)"
      },
      {
        "command": "cursorTaskFlow.openDashboard",
        "title": "Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "cursorTaskFlow.addTask",
        "title": "Create New Task",
        "icon": "$(add)"
      },
      {
        "command": "cursorTaskFlow.openLogs",
        "title": "Open Debug Logs",
        "icon": "$(output)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cursorTaskFlow.refreshTasks",
          "when": "view == cursorTaskFlowView",
          "group": "navigation"
        },
        {
          "command": "cursorTaskFlow.openDashboard",
          "when": "view == cursorTaskFlowView",
          "group": "navigation"
        },
        {
          "command": "cursorTaskFlow.addTask",
          "when": "view == cursorTaskFlowView",
          "group": "navigation"
        },
        {
          "command": "cursorTaskFlow.openLogs",
          "when": "view == cursorTaskFlowView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "cursorTaskFlow.deleteTask",
          "when": "view == cursorTaskFlowView",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Cursor Task Flow",
      "properties": {
        "cursorTaskFlow.telegramBotToken": {
          "type": "string",
          "default": "",
          "description": "Your Telegram Bot API Token from @BotFather."
        },
        "cursorTaskFlow.enableTelegramSync": {
          "type": "boolean",
          "default": false,
          "description": "Enable or disable real-time Telegram sync."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.1.3",
    "tslint": "^6.1.3",
    "eslint": "^8.41.0",
    "@typescript-eslint/parser": "^5.59.5",
    "@typescript-eslint/eslint-plugin": "^5.59.5",
    "@vscode/test-electron": "^2.3.2"
  }
}